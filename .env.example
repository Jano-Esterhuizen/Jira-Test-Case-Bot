# Copy this file to .env and fill in real values. Keep .env private.

# --- Jira (Atlassian cloud) ---
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=you@mercedes-benz.com
JIRA_API_TOKEN=your-jira-api-token

# --- Internal GitHub Enterprise ---
# Token created on git.i.mercedes-benz.com (Settings -> Developer settings -> Tokens)
GH_TOKEN=your-internal-github-token
GITHUB_API_BASE=https://git.i.mercedes-benz.com/api/v3
GITHUB_WEB_HOST=git.i.mercedes-benz.com
# Set to false ONLY if the internal server uses a corporate certificate
# that Python doesn't trust and IT can't give you the CA bundle:
GH_VERIFY_TLS=true

# --- Claude API ---
ANTHROPIC_API_KEY=your-anthropic-api-key
MODEL=claude-sonnet-4-6

# --- Behavior ---
# Which tickets to scan (Jira JQL):
JQL=assignee = currentUser() AND statusCategory != Done AND updated >= -5d
# true  = wait for a PR link before generating (retries each run)
# false = generate ticket-only test cases immediately if no link
REQUIRE_PR_LINK=true
