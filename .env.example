# Copy this file to .env and fill in real values. Keep .env private.

# --- Jira (Atlassian cloud) ---
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=you@mercedes-benz.com
JIRA_API_TOKEN=your-jira-api-token

# --- GitHub hosts (one numbered block per host: GH_HOST_1, GH_HOST_2, ...) ---
# The bot detects which host each PR link uses and picks the matching API
# base + token automatically. Add as many blocks as you need (up to 20).
#
# GH_API for each host type:
#   Enterprise Server : https://<host>/api/v3
#   Enterprise Cloud  : https://api.<subdomain>.ghe.com   (data residency, *.ghe.com)

# Host 1: GitHub Enterprise Server
GH_HOST_1=git.i.mercedes-benz.com
GH_API_1=https://git.i.mercedes-benz.com/api/v3
GH_TOKEN_1=token-created-on-git.i.mercedes-benz.com
# Set to false ONLY if this host uses a corporate certificate Python doesn't trust:
GH_VERIFY_TLS_1=true

# Host 2: GitHub Enterprise Cloud (data residency) — delete this block if unused
GH_HOST_2=yourcompany.ghe.com
GH_API_2=https://api.yourcompany.ghe.com
GH_TOKEN_2=token-created-on-yourcompany.ghe.com
GH_VERIFY_TLS_2=true

# --- Claude API ---
ANTHROPIC_API_KEY=your-anthropic-api-key
MODEL=claude-sonnet-4-6

# --- Behavior ---
# Which tickets to scan (Jira JQL):
JQL=assignee = currentUser() AND statusCategory != Done AND updated >= -5d
# false = generate immediately even without a PR link (ticket-only cases)
# true  = wait for a PR link before generating (retries each run)
REQUIRE_PR_LINK=false
